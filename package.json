{
  "name": "canvaskit",
  "version": "1.0.0",
  "description": "TypeScript app combining pixi.js and Skia (CanvasKit) with custom PIXI.Container-to-Skia rendering, interactive events, and vector PDF export via Skia PDF backend.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "keywords": [
    "vite",
    "typescript"
  ],
  "author": "Alexey4717",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "canvaskit-wasm": "^0.41.1",
    "pixi.js-legacy": "^7.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
